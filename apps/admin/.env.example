NEXT_PUBLIC_API_URL=http://localhost:8000
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true

# --- Backend gateway proxy ---
# Worker base URL (defaults to https://api.hieu.asia when unset).
HIEU_API_GATEWAY_URL=https://api.hieu.asia
# Shared admin token forwarded as X-Admin-Token by /api/admin-proxy/* and the
# per-endpoint proxy routes. Without this, all admin pages fall back to mock
# data. Get value from `wrangler secret list` on the worker.
HIEU_API_ADMIN_TOKEN=

# --- Supabase (optional, for direct REST reads from the browser) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
