NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SENTRY_DSN=https://eeadc49dcff33a6f06caf45df6ac9afe@o4511428225335296.ingest.us.sentry.io/4511428239360000
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true

# --- Backend gateway proxy ---
# Worker base URL (defaults to https://api.hieu.asia when unset).
HIEU_API_GATEWAY_URL=https://api.hieu.asia
# Shared admin token forwarded as X-Admin-Token by /api/admin-proxy/* and the
# per-endpoint proxy routes. Without this, all admin pages fall back to mock
# data. Get value from `wrangler secret list` on the worker.
HIEU_API_ADMIN_TOKEN=

# --- Admin session cookie ---
# REQUIRED. HMAC-SHA256 key that signs the admin session cookie. Fail-closed:
# unset → login refuses to issue a session and every request is rejected.
# Generate: openssl rand -base64 32
ADMIN_COOKIE_SECRET=
# Optional break-glass password for admin@hieu.asia, used ONLY when the worker
# auth call fails. Leave empty in normal operation.
ADMIN_PASSWORD=

# --- Supabase (optional, for direct REST reads from the browser) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy fallback (deprecated by Supabase Oct 2025+)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase server-side (service role — NEVER expose to the browser) ---
# Read by lib/supabase-server.ts. Both names work; HIEU_* is checked first.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
HIEU_SUPABASE_SERVICE_ROLE_KEY=

# --- PostHog ---
# Browser SDK (analytics on the admin app itself).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# Server-side read of PostHog insights for the Analytics panel. Personal API
# key from PostHog → Settings → Personal API keys. Unset → panel shows a
# "chưa cấu hình" state instead of live numbers.
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=434217
POSTHOG_API_HOST=https://us.posthog.com
# Deep links from the admin UI into the PostHog app (optional).
NEXT_PUBLIC_POSTHOG_PROJECT_ID=
NEXT_PUBLIC_POSTHOG_DASHBOARD_URL=

# --- Ahrefs (SEO panel, optional) ---
# Unset → the SEO panel renders empty instead of calling the Ahrefs API.
AHREFS_API_KEY=
AHREFS_TARGET=hieu.asia

# --- Misc ---
# Public site origin, used to build "xem trên web" links. Unset → https://hieu.asia
NEXT_PUBLIC_WEB_URL=https://hieu.asia
# Vercel deploy-hook URL used by /api/admin/regen-sitemap to trigger a rebuild.
VERCEL_ADMIN_DEPLOY_HOOK=

# --- Build only (not needed for `pnpm dev`) ---
# Sentry source-map upload during `next build`.
# SENTRY_AUTH_TOKEN=
# `ANALYZE=true pnpm build` → bundle analyzer report.
# ANALYZE=
#
# NOTE: NODE_ENV, NEXT_RUNTIME and every VERCEL_* variable are injected by
# Next.js / Vercel — do not set them by hand.
