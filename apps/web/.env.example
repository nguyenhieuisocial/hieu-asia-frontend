# Public — browser-readable
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SOCKET_URL=http://localhost:8000
NEXT_PUBLIC_SENTRY_DSN=https://eeadc49dcff33a6f06caf45df6ac9afe@o4511428225335296.ingest.us.sentry.io/4511428239360000

# Canonical site origin — used by sendMagicLink + signInWithOAuth for emailRedirectTo.
# On Vercel prod, set to https://hieu.asia. Falls back to window.location.origin if unset.
# Bug history: missing this caused magic-link emails to ship with http://localhost:3000 links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy fallback (deprecated by Supabase Oct 2025+)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — Auth.js v5 (stub for now)
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true

# Optional providers (Phase 2)
# AUTH_TELEGRAM_BOT_TOKEN=
# AUTH_EMAIL_SERVER=
# AUTH_EMAIL_FROM=

# PostHog — browser analytics, session replay, feature flags, surveys.
# Project key: PostHog dashboard → Project Settings → "Project API Key".
# Host: pick the region your project is hosted in.
#   EU: https://eu.i.posthog.com   (default if NEXT_PUBLIC_POSTHOG_HOST unset)
#   US: https://us.i.posthog.com
# Missing key → PostHog silently disables; build + runtime stay green.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# --- Cloudflare Worker gateway (server-only route handlers) ---
# Base URL of the api-gateway worker. Both names are read; HIEU_API_URL is the
# one most /api/* proxies use, HIEU_API_GATEWAY_URL is read by /api/user/me.
# Unset → both fall back to https://api.hieu.asia.
HIEU_API_URL=https://api.hieu.asia
HIEU_API_GATEWAY_URL=https://api.hieu.asia
# Service token sent as X-Service-Token by the server-side proxies
# (/api/account/export, /api/account/erase, /api/affiliate/*). Unset → those
# routes return "not configured" instead of calling the worker.
# Value: `wrangler secret list` on the worker.
HIEU_API_SERVICE_TOKEN=
# Token for the mentor/reading stream proxy (/api/mentor, /api/mentor/stream).
READING_PROXY_TOKEN=

# --- Supabase server-side (service role — NEVER expose to the browser) ---
# Used by /api/audit/log, /api/email/*, /api/onboarding/complete.
# SUPABASE_URL falls back to the public project URL when unset.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Alias read first by /api/onboarding/complete (same value as above).
HIEU_SUPABASE_SERVICE_ROLE_KEY=

# --- Email (Resend) — newsletter + Wave 58 drip ---
# Both must be set or /api/email/subscribe returns "email_disabled".
RESEND_API_KEY=
RESEND_NEWSLETTER_AUDIENCE_ID=
# HMAC key that signs one-click unsubscribe links (/api/email/unsubscribe).
UNSUBSCRIBE_HMAC_SECRET=
# Shared secret the drip cron must present to POST /api/email/wave58-drip.
WAVE58_DRIP_CRON_SECRET=

# --- Langfuse — LLM tracing for the reasoning graph (optional) ---
# Missing keys → tracing silently disabled, reasoning still works.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Public site origin used in SERVER metadata/JSON-LD ---
# Separate from NEXT_PUBLIC_SITE_URL above (that one is browser-side auth
# redirects). Unset → https://hieu.asia.
PUBLIC_SITE_URL=https://hieu.asia

# --- Optional public integrations (all have safe fallbacks) ---
# Cloudflare Turnstile — bot check on the auth forms.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Web Push (VAPID public key). Unset → the "bật nhắc nhở" button stays hidden.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# Telegram bot deep link shown in Settings. Unset → https://t.me/hieuasiabot
NEXT_PUBLIC_TELEGRAM_BOT_URL=
# Fallback alias for NEXT_PUBLIC_API_URL (PDF download button only).
NEXT_PUBLIC_HIEU_API_URL=

# --- Marketing / analytics tags (all optional; unset = tag not injected) ---
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_FB_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_AHREFS_ANALYTICS_KEY=
# Plausible (self-hosted or cloud). Domain unset → script not injected.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_SRC=

# --- Build / CI only (not needed for `pnpm dev`) ---
# Sentry source-map upload during `next build`. Unset → maps not uploaded.
# SENTRY_AUTH_TOKEN=
# `ANALYZE=true pnpm build` → bundle analyzer report.
# ANALYZE=
# Base URL for the Playwright suites (a11y / journey / visual).
# PLAYWRIGHT_BASE_URL=https://hieu.asia
#
# NOTE: NODE_ENV, NEXT_RUNTIME, CI and every VERCEL_* / NEXT_PUBLIC_VERCEL_*
# variable are injected by Next.js / Vercel — do not set them by hand.
