# Public — browser-readable
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SOCKET_URL=http://localhost:8000
NEXT_PUBLIC_SENTRY_DSN=https://eeadc49dcff33a6f06caf45df6ac9afe@o4511428225335296.ingest.us.sentry.io/4511428239360000

# Canonical site origin — used by sendMagicLink + signInWithOAuth for emailRedirectTo.
# On Vercel prod, set to https://hieu.asia. Falls back to window.location.origin if unset.
# Bug history: missing this caused magic-link emails to ship with http://localhost:3000 links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy fallback (deprecated by Supabase Oct 2025+)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — Auth.js v5 (stub for now)
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true

# Optional providers (Phase 2)
# AUTH_TELEGRAM_BOT_TOKEN=
# AUTH_EMAIL_SERVER=
# AUTH_EMAIL_FROM=

# PostHog — browser analytics, session replay, feature flags, surveys.
# Project key: PostHog dashboard → Project Settings → "Project API Key".
# Host: pick the region your project is hosted in.
#   EU: https://eu.i.posthog.com   (default if NEXT_PUBLIC_POSTHOG_HOST unset)
#   US: https://us.i.posthog.com
# Missing key → PostHog silently disables; build + runtime stay green.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
