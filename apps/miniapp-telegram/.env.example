NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true

# --- Telegram WebApp initData verification (POST /api/auth/telegram) ---
# Bot token of @hieuasiabot. Server-only: it is the HMAC key that proves the
# `telegram_id` really came from Telegram. Unset → the route refuses to sign in.
TELEGRAM_BOT_TOKEN=
# Supabase project the verified user is upserted into (service role — server
# only, NEVER expose to the browser).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- PostHog (optional) ---
# Unset key → analytics silently disabled, the mini-app still runs.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
#
# NOTE: NODE_ENV is injected by Next.js — do not set it by hand.
