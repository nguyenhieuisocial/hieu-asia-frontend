# hieu.asia Zalo mini-app — env vars
#
# Wave 33 #161: all three values below are PUBLIC (browser-safe) per the
# Supabase + Cloudflare Workers security model:
#   - VITE_EDGE_FN_URL is the canonical public Edge Functions endpoint.
#   - VITE_SUPABASE_ANON_KEY is the publishable key (`sb_publishable_*` format)
#     — see https://supabase.com/docs/guides/api/api-keys; anon key is the
#     intended browser-side identity, RLS policies (migration 0011) gate
#     anything sensitive.
#   - VITE_API_URL is the public Cloudflare Worker domain.
#
# Copy this file to `.env` to run `pnpm dev` / `zmp deploy` locally.
# (.env is gitignored — keep secrets there if you ever add server-side ones.)

VITE_EDGE_FN_URL=https://fvftbqairezsybasqsek.supabase.co/functions/v1
VITE_SUPABASE_ANON_KEY=sb_publishable_3sYizQHndGbiOBepgbF0Mw_q5h_6vAJ
VITE_API_URL=https://api.hieu.asia

# PostHog (optional) — note the VITE_PUBLIC_ prefix, it differs from the three
# VITE_ vars above. Unset key → analytics is a silent no-op, the app still runs.
# Host unset → defaults to the EU region.
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
